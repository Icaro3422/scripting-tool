# Database (Podman/PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scripting_tool"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Clerk webhooks (future wallets)
# CLERK_WEBHOOK_SECRET=

# YouTube Data API v3 (canal analysis)
YOUTUBE_API_KEY=

# AI Providers (use the ones you need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_AI_API_KEY=

# OpenRouter: un solo API key para 400+ modelos (gratis y de pago). Ver https://openrouter.ai/models
OPENROUTER_API_KEY=

# Storage: Cloudinary para miniaturas en la nube (o usa modo Local en la app)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Hugging Face (TTS / voices)
HUGGINGFACE_API_KEY=
